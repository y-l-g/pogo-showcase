{
	skip_install_trust

	admin {$CADDY_ADMIN:localhost:2019}

	pogo_showcase_bootstrap

	frankenphp {
		max_requests {$FRANKENPHP_MAX_REQUESTS:1000}

		worker {
			file {$POGO_SHOWCASE_APP_PATH:.}/public/frankenphp-worker.php
			num {$HTTP_WORKERS:4}
			name http
			env MAX_REQUESTS {$HTTP_MAX_REQUESTS:1000}
		}
	}

	pogo {
		worker {$POGO_SHOWCASE_APP_PATH:.}/public/pogo-worker.php
		num_threads {$POGO_DEFAULT_THREADS:4}
		max_wait 30s

		pool external_api {
			worker {$POGO_SHOWCASE_APP_PATH:.}/public/pogo-worker.php
			num_threads {$POGO_EXTERNAL_API_THREADS:8}
			max_wait 10s
		}
	}

	pogo_queue {
		backend memory {
			max_messages {$POGO_QUEUE_SIZE:10000}
			max_total_bytes {$POGO_QUEUE_MAX_TOTAL_BYTES:67108864}
		}

		worker {$POGO_SHOWCASE_APP_PATH:.}/public/queue-worker.php
		queues {$POGO_QUEUE:default}
		concurrency {$POGO_QUEUE_CONCURRENCY:4}
		worker_threads {$POGO_QUEUE_THREADS:4}
		max_payload_bytes {$POGO_QUEUE_MAX_MESSAGE_BYTES:1048576}
		visibility_timeout {$POGO_QUEUE_VISIBILITY_TIMEOUT:90s}
		shutdown_timeout {$POGO_QUEUE_SHUTDOWN_TIMEOUT:30s}
		max_attempts {$POGO_QUEUE_MAX_ATTEMPTS:3}
	}

	pogo_scheduler {
		command /proc/self/exe php-cli artisan schedule:run
		dir {$POGO_SHOWCASE_APP_PATH:.}
		timeout {$POGO_SCHEDULER_TIMEOUT:2m}
		overlap allow
		shutdown_grace 30s
	}

	order pogo_websocket before php_server
}

{$SERVER_NAME:localhost} {
	log {
		level {$CADDY_SERVER_LOG_LEVEL:INFO}
		format filter {
			wrap console
			fields {
				uri query {
					replace authorization REDACTED
				}
			}
		}
	}

	@websocket path /app/* /apps/* /up /pogo/health
	route @websocket {
		pogo_websocket {
			allowed_origins {$POGO_WS_ALLOWED_ORIGINS:*}

			handshake_rate {$POGO_WS_HANDSHAKE_RATE:100}
			handshake_burst {$POGO_WS_HANDSHAKE_BURST:50}
			max_connections {$POGO_WS_MAX_CONNECTIONS:10000}
			max_auth_body {$POGO_WS_MAX_AUTH_BODY:16384}
			max_concurrent_auth {$POGO_WS_MAX_CONCURRENT_AUTH:100}
			broker_queue_size {$POGO_WS_BROKER_QUEUE_SIZE:1024}
			shard_queue_size {$POGO_WS_SHARD_QUEUE_SIZE:1024}

			num_shards {$POGO_WS_SHARDS:8}

			ping_period 54s
			pong_wait 60s
			write_wait 10s
		}
	}

	route {
		root * {$POGO_SHOWCASE_APP_PATH:.}/public
		encode zstd br gzip

		php_server {
			index frankenphp-worker.php
			try_files {path} frankenphp-worker.php
			resolve_root_symlink
		}
	}
}
